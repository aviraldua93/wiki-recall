{
  "name": "wiki-recall",
  "version": "0.1.0",
  "description": "Portable AI-driven working scenarios — Docker for your engineering brain",
  "type": "module",
  "bin": {
    "wiki-recall": "src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun build src/cli/index.ts --compile --outfile=wikirecall",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:e2e": "bun test tests/e2e",
    "lint": "bunx tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "openai": "^4.73.0",
    "pino": "^9.6.0",
    "sonic-boom": "^4.2.0",
    "uuid": "^11.1.0",
    "better-sqlite3": "^11.7.0",
    "gray-matter": "^4.0.3",
    "glob": "^11.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0",
    "chalk": "^5.4.0",
    "ora": "^8.0.0",
    "inquirer": "^12.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/uuid": "^10.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.7.0"
  },
  "author": "Aviral Dua",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aviraldua93/wiki-recall.git"
  },
  "keywords": [
    "wiki-recall",
    "developer-productivity",
    "working-scenarios",
    "cli",
    "ai",
    "copilot",
    "knowledge-base",
    "session-management",
    "skills"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "homepage": "https://github.com/aviraldua93/wiki-recall#readme",
  "bugs": {
    "url": "https://github.com/aviraldua93/wiki-recall/issues"
  },
  "mcp": {
    "server": {
      "command": "bun",
      "args": ["run", "src/cli/index.ts", "mcp"],
      "transport": "stdio"
    }
  },
  "files": [
    "src",
    "schemas",
    "skills",
    "templates",
    "README.md",
    "LICENSE"
  ]
}
